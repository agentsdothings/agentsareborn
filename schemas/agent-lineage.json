{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsdothings.com/schemas/agentsareborn/agent-lineage.json",
  "title": "Agent Lineage",
  "type": "object",
  "required": ["agentId", "events"],
  "properties": {
    "agentId": { "type": "string" },
    "creatorId": { "type": "string" },
    "parentAgentIds": { "type": "array", "items": { "type": "string" } },
    "templateIds": { "type": "array", "items": { "type": "string" } },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "occurredAt"],
        "properties": {
          "type": { "type": "string" },
          "occurredAt": { "type": "string", "format": "date-time" },
          "summary": { "type": "string" },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
