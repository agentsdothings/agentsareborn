{
  "name": "@agentsdo/agentsareborn",
  "version": "0.1.0",
  "description": "A bio-accelerator for synthetic beings in the Agents Do Things ecosystem",
  "type": "module",
  "license": "MIT",
  "author": "Agents Do Things",
  "homepage": "https://github.com/agentsdothings/agentsareborn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentsdothings/agentsareborn.git"
  },
  "bugs": {
    "url": "https://github.com/agentsdothings/agentsareborn/issues"
  },
  "keywords": [
    "agents",
    "autonomous-agents",
    "agent-manifest",
    "agents-do-things",
    "cli",
    "typescript"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./birth": {
      "types": "./dist/src/birth.d.ts",
      "import": "./dist/src/birth.js"
    },
    "./auth-bridge": {
      "types": "./dist/src/auth-bridge.d.ts",
      "import": "./dist/src/auth-bridge.js"
    },
    "./adt-action-runner": {
      "types": "./dist/src/adt-action-runner.d.ts",
      "import": "./dist/src/adt-action-runner.js"
    },
    "./stable": {
      "types": "./dist/src/stable.d.ts",
      "import": "./dist/src/stable.js"
    },
    "./package.json": "./package.json",
    "./first-breath": {
      "types": "./dist/src/first-breath.d.ts",
      "import": "./dist/src/first-breath.js"
    }
  },
  "bin": {
    "agentsareborn": "dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "dist/scripts/",
    "src/",
    "schemas/",
    "examples/",
    "docs/",
    "site/",
    "agent-native.json",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "PUBLIC_RELEASE.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "validate:json": "node dist/scripts/validate-json.js",
    "verify": "npm test && npm run validate:json",
    "prepack": "npm run verify",
    "prepublishOnly": "npm run verify",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:package": "npm run build && node -e \"import('./dist/src/index.js').then(m=>{ if (!m.birthPlatformBuilders || !m.firstBreath || !m.StableStore) process.exit(1) })\" && test \"$(node dist/src/cli.js version)\" = \"0.1.0\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
